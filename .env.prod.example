cat > .env.prod <<'EOF'
DOMAIN=coffee-stop.ru

# ===== Container images (prebuilt and pushed to your registry) =====
COFFEE_STOP_BACKEND_IMAGE=ghcr.io/updeer/coffee-stop1-backend:latest
COFFEE_STOP_GUEST_IMAGE=ghcr.io/updeer/coffee-stop1-guest:latest
COFFEE_STOP_BARISTA_IMAGE=ghcr.io/updeer/coffee-stop1-barista:latest

# ===== Database =====
# 1) Set any strong password yourself (you choose it)
DB_PASSWORD=NeW_STR0NG_db_PA
# 2) Must match DB_PASSWORD above (same value after "coffeestop:")
DATABASE_URL=postgresql+psycopg://coffeestop:NeW_STR0NG_db_PA@db:5432/coffeestop

# ===== CORS =====
# Replace with your real domains:
# https://guest.<DOMAIN>,https://barista.<DOMAIN>
CORS_ORIGINS=https://guest.coffee-stop.ru,https://barista.coffee-stop.ru,https://api.coffee-stop.ru

# ===== Email =====
# SMTP provider settings (Mailgun/SendGrid/Yandex/etc.)
MAIL_HOST=mail.mail.coffee-stop.ru
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USER=coffee_stop@mail.coffee-stop.ru
MAIL_PASSWORD=92jCZu6yX6pxjuk
MAIL_FROM=Coffee Stop <coffee_stop@mail.coffee-stop.ru>
EOF