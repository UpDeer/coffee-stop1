# ===== Base domain =====
DOMAIN=example.com

# ===== Container images (prebuilt and pushed to your registry) =====
COFFEE_STOP_BACKEND_IMAGE=ghcr.io/updeer/coffee-stop1-backend:latest
COFFEE_STOP_GUEST_IMAGE=ghcr.io/updeer/coffee-stop1-guest:latest
COFFEE_STOP_BARISTA_IMAGE=ghcr.io/updeer/coffee-stop1-barista:latest

# ===== Database =====
DB_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://coffeestop:change_me@db:5432/coffeestop

# ===== CORS =====
CORS_ORIGINS=https://guest.example.com,https://barista.example.com

# ===== Email =====
MAIL_HOST=
MAIL_PORT=587
MAIL_FROM=Coffee Stop <no-reply@example.com>
MAIL_USER=
MAIL_PASSWORD=
MAIL_USE_TLS=true

# ===== Tochka API =====
TOCHKA_API_BASE_URL=https://enter.tochka.com
TOCHKA_API_BEARER_TOKEN=
TOCHKA_CUSTOMER_CODE=
TOCHKA_MERCHANT_ID=
TOCHKA_PAYMENT_PURPOSE=Оплата заказа Coffee Stop
TOCHKA_PAYMENT_REDIRECT_URL=https://guest.example.com/s/demo/order
TOCHKA_PAYMENT_FAIL_REDIRECT_URL=https://guest.example.com/s/demo/pay-failed
TOCHKA_PAYMENT_TTL_MINUTES=1440
TOCHKA_PAYMENT_MODES=card,sbp
TOCHKA_WEBHOOK_PUBLIC_JWK_JSON=

# ===== Evotor =====
# disabled | mock_done | mock_failed | real
EVOTOR_INTEGRATION_MODE=real
EVOTOR_FISCALIZATION_URL=
EVOTOR_LOGIN=
EVOTOR_PASSWORD=
EVOTOR_GROUP_CODE=
EVOTOR_CASHIER_UUID=
