        <mxCell id="c7" value="Забирает заказ&#xa;&lt;font style=&quot;font-size: 11px;&quot;&gt;готово&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8B5CF6;strokeWidth=2;fontSize=13;fontStyle=1" vertex="1" parent="1">
