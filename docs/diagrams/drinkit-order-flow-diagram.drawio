        <mxCell id="r3" value="Кладёт в ячейку&#xa;&lt;font style=&quot;font-size: 11px;&quot;&gt;умная выдача&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#F59E0B;strokeWidth=2;fontSize=13;fontStyle=1" vertex="1" parent="1">
