  <diagram name="Процесс заказа" id="drinkit-order-flow">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="950" pageBackground="#ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Процесс заказа: от приложения до умной выдачи" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="800" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Клиент → Приложение/Киоск → Бэкенд → Бариста → Умная выдача" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#6b7280" vertex="1" parent="1">
          <mxGeometry x="350" y="58" width="900" height="24" as="geometry" />
        </mxCell>

        <!-- Lane headers -->
        <mxCell id="lane1" value="Клиент" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#E5E7EB;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="220" height="36" as="geometry" />
        </mxCell>
        <mxCell id="lane2" value="Приложение / Киоск" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#E5E7EB;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="280" y="100" width="220" height="36" as="geometry" />
        </mxCell>
        <mxCell id="lane3" value="Бэкенд (Dodo IS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#E5E7EB;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="520" y="100" width="280" height="36" as="geometry" />
        </mxCell>
        <mxCell id="lane4" value="Бариста (планшет)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#E5E7EB;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="820" y="100" width="220" height="36" as="geometry" />
        </mxCell>
        <mxCell id="lane5" value="Умная выдача (ячейки)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#E5E7EB;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1060" y="100" width="260" height="36" as="geometry" />
        </mxCell>

        <!-- Client steps -->
        <mxCell id="c1" value="Выбирает точку&#xa;&lt;font style=&quot;font-size: 11px;&quot;&gt;ближайшая/нужная&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8B5CF6;strokeWidth=2;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="180" height="56" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="Собирает заказ&#xa;&lt;font style=&quot;font-size: 11px;&quot;&gt;добавки, крепость, молоко&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8B5CF6;strokeWidth=2;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="235" width="180" height="56" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="Оплачивает&#xa;&lt;font style=&quot;font-size: 11px;&quot;&gt;в приложении/киоске&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8B5CF6;strokeWidth=2;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="310" width="180" height="56" as="geometry" />
        </mxCell>
        <mxCell id="c4" value="Получает push «Готово»&#xa;&lt;font style=&quot;font-size: 11px;&quot;&gt;статус заказа&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8B5CF6;strokeWidth=2;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="385" width="180" height="56" as="geometry" />
        </mxCell>
        <mxCell id="c5" value="Приходит к выдаче&#xa;&lt;font style=&quot;font-size: 11px;&quot;&gt;без очереди у кассы&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8B5CF6;strokeWidth=2;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="460" width="180" height="56" as="geometry" />
        </mxCell>
