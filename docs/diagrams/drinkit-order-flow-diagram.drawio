        <mxCell id="b4" value="Привязка к ячейке&#xa;&lt;font style=&quot;font-size: 11px;&quot;&gt;ячейка N&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#10B981;strokeWidth=2;fontSize=13;fontStyle=1" vertex="1" parent="1">
