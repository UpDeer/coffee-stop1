        <mxCell id="b2" value="Ставит в очередь&#xa;&lt;font style=&quot;font-size: 11px;&quot;&gt;для точки&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#10B981;strokeWidth=2;fontSize=13;fontStyle=1" vertex="1" parent="1">
