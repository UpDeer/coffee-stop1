# Скопируй в .env и подставь свои значения (для будущего бэкенда)
# SQLAlchemy + psycopg v3
DATABASE_URL=postgresql+psycopg://coffeestop:coffeestop@localhost:5432/coffeestop

# Email (локально через MailHog из docker-compose)
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_FROM=Coffee Stop <no-reply@coffee-stop.local>
# Для MailHog auth не нужен
MAIL_USER=
MAIL_PASSWORD=
MAIL_USE_TLS=false

# Tochka API (payment links + acquiringInternetPayment webhook)
TOCHKA_API_BASE_URL=https://enter.tochka.com
TOCHKA_API_BEARER_TOKEN=
TOCHKA_CUSTOMER_CODE=
TOCHKA_MERCHANT_ID=
TOCHKA_PAYMENT_PURPOSE=Оплата заказа Coffee Stop
TOCHKA_PAYMENT_REDIRECT_URL=
TOCHKA_PAYMENT_FAIL_REDIRECT_URL=
TOCHKA_PAYMENT_TTL_MINUTES=1440
TOCHKA_PAYMENT_MODES=card,sbp
# JWK JSON для проверки RS256 подписи webhook (вставить целиком как JSON-строку)
TOCHKA_WEBHOOK_PUBLIC_JWK_JSON=

# Evotor Digital Cashbox (fiscalization after payment)
EVOTOR_INTEGRATION_MODE=disabled
EVOTOR_FISCALIZATION_URL=
EVOTOR_LOGIN=
EVOTOR_PASSWORD=
EVOTOR_GROUP_CODE=
EVOTOR_CASHIER_UUID=
